apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: my-service
spec:
  minAvailable: 1
  selector:
    matchLabels:
      app: my-service


resource "kubernetes_pod_disruption_budget_v1" "my_service" {
  metadata {
    name      = "my-service-pdb"
    namespace = "default"
  }

  spec {
    min_available = 1

    selector {
      match_labels = {
        app = "my-service"
      }
    }
  }
}
